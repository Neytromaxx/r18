# m21 backend API bazasi (oxiri /api/v1). MUHIM: overlay WebSocket shu hostning
# ildizidagi /ws yo'lidan ulanadi (wss://<host>/ws...) — API va WS bir hostda
# bo'lishi shart.
VITE_API_URL=https://api.example.uz/api/v1

# Google orqali kirish (ixtiyoriy). Google Console'da mydonation.uz
# "Authorized JavaScript origins" ro'yxatiga qo'shilgan bo'lishi kerak.
VITE_GOOGLE_CLIENT_ID=
